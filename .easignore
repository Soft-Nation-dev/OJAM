# EAS upload exclusions

# Keep this focused on generated outputs, local tooling data, and heavy non-build assets.

# Dependency/build artifacts

node_modules/
.expo/
dist/
build/
coverage/
OJAM/
friday/
# Android generated files (native sources are still included)

android/.gradle/
android/\*\*/build/
android/local.properties

# Git/IDE/system noise

.git/
.idea/
.DS_Store
Thumbs.db

# Logs and archives

_.log
_.bak
_.zip
_.tar
\*.tar.gz

# Large workspace-only folders not required for cloud builds

perf-reports/
scripts/
database/
sermon-sync/
OJAM/

# Optional bulky asset folders not used by current app bundle

assets/videos/
assets/audio/
